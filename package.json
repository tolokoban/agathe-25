{
    "name": "agathe-25",
    "description": "Anniversaire d'Agathe",
    "version": "0.1.1",
    "private": true,
    "sideEffects": [
        "*.css"
    ],
    "homepage": "https://tolokoban.github.io/...",
    "dependencies": {
        "@tolokoban/type-guards": "^0.9.0",
        "@tolokoban/react-state": "^0.7.3",
        "@tolokoban/ui": "^0.25.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "scripts": {
        "clean": "rm -rf src/generated",
        "generate": "npm run optimize && npm run routes",
        "optimize": "node scripts/optimize-images/optimize-images.mjs",
        "routes": "build-react-routes src/app",
        "start": "webpack serve --mode=development",
        "build": "webpack --mode=production",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build/",
        "lint": "eslint -c .eslintrc.yml 'src/**/*.ts' 'src/**/*.tsx'",
        "format": "prettier --write ./src/",
        "test": "jest"
    },
    "eslintConfig": {
        "extends": "react-app"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@babel/preset-typescript": "^7.28.5",
        "@mdx-js/loader": "^3.1.1",
        "@types/jest": "^30.0.0",
        "@types/mdx": "^2.0.13",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "babel-jest": "^30.2.0",
        "babel-loader": "^10.0.0",
        "build-react-routes": "^0.10.8",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^13.0.1",
        "css-loader": "^6.11.0",
        "esbuild-loader": "^4.4.0",
        "file-loader": "^6.2.0",
        "gh-pages": "^6.3.0",
        "html-webpack-plugin": "^5.6.6",
        "jest": "^30.2.0",
        "json-loader": "^0.5.7",
        "markdown-to-jsx": "^9.7.6",
        "mini-css-extract-plugin": "^2.10.0",
        "prettier": "3.8.1",
        "sharp": "^0.34.5",
        "style-loader": "^3.3.4",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tslint": "^6.1.3",
        "typescript": "^5.9.3",
        "url-loader": "^4.1.1",
        "webpack": "^5.105.2",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.0",
        "webpack-shell-plugin-next": "^2.3.2",
        "workbox-webpack-plugin": "^7.3.0"
    },
    "port": 10085
}